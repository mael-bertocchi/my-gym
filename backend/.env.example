# Global configuration
NODE_ENV="development"
PORT="3000"

# CORS configuration
CORS_ORIGINS="http://localhost:3000,http://localhost:8081,http://localhost:19006"

# Database configuration
DATABASE_URL="postgresql://username:password@localhost:5432/my_gym"

# Azure AI Foundry configuration
AZURE_AI_ENDPOINT="https://your-instance.openai.azure.com/openai/deployments/your-model/chat/completions?api-version=2024-02-01"
AZURE_AI_API_KEY="your-azure-ai-api-key"
