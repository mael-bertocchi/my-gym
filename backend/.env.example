# Global configuration
NODE_ENV="development"
PORT="3000"

# CORS configuration
CORS_ORIGINS="http://localhost:3000,http://localhost:8081,http://localhost:19006"

# Database configuration
DATABASE_URL="postgresql://username:password@localhost:5432/my_gym"

# Google AI Studio configuration
GOOGLE_AI_STUDIO_API_KEY="your-google-ai-studio-api-key"
GOOGLE_AI_MODEL="gemini-2.5-flash"

# Administrator account
ADMINISTRATOR_EMAIL="you@example.com"
ADMINISTRATOR_PASSWORD="change-me-at-least-8-chars"

# JWT configuration
JWT_SECRET="change-me-to-a-long-random-string"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"
