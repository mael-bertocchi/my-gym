// my-gym — personal single-user workout tracker.
// Conventions mirror JetAviation/Vector/Backend: UUID string PKs, camelCase
// fields mapped to snake_case columns/tables, created/updated timestamps.
// The datasource connection URL is supplied at runtime via prisma.config.ts.

generator client {
  provider            = "prisma-client"
  output              = "./generated/prisma"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

enum WeightUnit {
  KG
  LBS
}

enum EquipmentType {
  BARBELL
  DUMBBELL
  MACHINE
  SMITH_MACHINE
  CABLE
  PLATE_LOADED
  KETTLEBELL
  RESISTANCE_BAND
  BODYWEIGHT
  EZ_BAR
  TRAP_BAR
  OTHER
}

enum MuscleGroup {
  CHEST
  UPPER_BACK
  LATS
  LOWER_BACK
  TRAPEZIUS
  FRONT_DELTS
  SIDE_DELTS
  REAR_DELTS
  BICEPS
  TRICEPS
  FOREARMS
  QUADRICEPS
  HAMSTRINGS
  GLUTES
  CALVES
  ABS
  OBLIQUES
  ADDUCTORS
  ABDUCTORS
  NECK
  FULL_BODY
}

enum SetType {
  WARMUP
  WORKING
  DROP
  FAILURE
}

enum AiContentStatus {
  PENDING
  GENERATED
  FAILED
}

/// The single administrator account that owns all data in this personal app.
model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String     @map("password_hash")
  firstname       String
  lastname        String
  isAdministrator Boolean    @default(false) @map("is_administrator")
  weightUnit      WeightUnit @default(KG) @map("weight_unit")

  exercises     Exercise[]
  machineBrands MachineBrand[]
  gymBrands     GymBrand[]
  workouts      Workout[]
  bodyweightLog BodyweightEntry[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model BodyweightEntry {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg   Decimal  @map("weight_kg") @db.Decimal(6, 2)
  measuredAt DateTime @map("measured_at")
  notes      String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, measuredAt])
  @@map("bodyweight_entries")
}

model Exercise {
  id               String        @id @default(uuid())
  userId           String        @map("user_id")
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  primaryMuscle    MuscleGroup   @map("primary_muscle")
  secondaryMuscles MuscleGroup[] @map("secondary_muscles")
  isArchived       Boolean       @default(false) @map("is_archived")

  variants ExerciseVariant[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, name])
  @@index([userId, primaryMuscle])
  @@map("exercises")
}

model ExerciseVariant {
  id              String          @id @default(uuid())
  exerciseId      String          @map("exercise_id")
  exercise        Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  equipmentType   EquipmentType   @map("equipment_type")
  machineBrandId  String?         @map("machine_brand_id")
  machineBrand    MachineBrand?   @relation(fields: [machineBrandId], references: [id], onDelete: Restrict)

  formSummary     String?         @map("form_summary")
  instructions    String?
  equipmentTips   String?         @map("equipment_tips")
  previewImageUrl String?         @map("preview_image_url")
  aiContentStatus AiContentStatus @default(PENDING) @map("ai_content_status")
  aiGeneratedAt   DateTime?       @map("ai_generated_at")

  workoutEntries WorkoutExercise[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([exerciseId, equipmentType, machineBrandId])
  @@index([machineBrandId])
  @@map("exercise_variants")
}

model MachineBrand {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String

  variants ExerciseVariant[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, name])
  @@map("machine_brands")
}

model GymBrand {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String

  locations GymLocation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, name])
  @@map("gym_brands")
}

model GymLocation {
  id         String   @id @default(uuid())
  gymBrandId String   @map("gym_brand_id")
  gymBrand   GymBrand @relation(fields: [gymBrandId], references: [id], onDelete: Cascade)
  name       String
  city       String?
  address    String?

  workouts Workout[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([gymBrandId, name])
  @@index([gymBrandId])
  @@map("gym_locations")
}

model Workout {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  gymLocationId String?      @map("gym_location_id")
  gymLocation   GymLocation? @relation(fields: [gymLocationId], references: [id], onDelete: SetNull)
  name          String?
  startedAt     DateTime     @map("started_at")
  endedAt       DateTime?    @map("ended_at")
  notes         String?

  entries WorkoutExercise[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, startedAt])
  @@index([gymLocationId])
  @@map("workouts")
}

model WorkoutExercise {
  id                String          @id @default(uuid())
  workoutId         String          @map("workout_id")
  workout           Workout         @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseVariantId String          @map("exercise_variant_id")
  exerciseVariant   ExerciseVariant @relation(fields: [exerciseVariantId], references: [id], onDelete: Restrict)
  position          Int
  notes             String?

  sets SetEntry[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([workoutId, position])
  @@index([exerciseVariantId])
  @@map("workout_exercises")
}

model SetEntry {
  id                String          @id @default(uuid())
  workoutExerciseId String          @map("workout_exercise_id")
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  setNumber         Int             @map("set_number")
  setType           SetType         @default(WORKING) @map("set_type")
  weightKg          Decimal?        @map("weight_kg") @db.Decimal(6, 2)
  reps              Int?
  rpe               Decimal?        @db.Decimal(3, 1)
  restSeconds       Int?            @map("rest_seconds")
  durationSeconds   Int?            @map("duration_seconds")
  tempo             String?
  notes             String?
  isCompleted       Boolean         @default(false) @map("is_completed")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([workoutExerciseId, setNumber])
  @@map("set_entries")
}
