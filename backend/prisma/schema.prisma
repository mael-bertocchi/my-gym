// my-gym — workout tracker backend.
// Conventions: UUID string PKs, camelCase fields mapped to snake_case columns/tables,
// created/updated timestamps. The datasource connection URL is supplied at runtime
// via prisma.config.ts. The catalog (brands, equipment, exercise groups, exercises,
// gyms) is shared and administrator-managed; workouts, remembered settings, and
// assistant conversations are per-user.

generator client {
  provider            = "prisma-client"
  output              = "./generated/prisma"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

enum WeightUnit {
  KG
  LBS
}

enum EquipmentType {
  MACHINE
  BARBELL
  DUMBBELL
  CABLE
  SMITH
  BODYWEIGHT
  KETTLEBELL
  CARDIO
  OTHER
}

enum MuscleGroup {
  CHEST
  UPPER_BACK
  LATS
  LOWER_BACK
  TRAPEZIUS
  FRONT_DELTS
  SIDE_DELTS
  REAR_DELTS
  BICEPS
  TRICEPS
  FOREARMS
  QUADRICEPS
  HAMSTRINGS
  GLUTES
  CALVES
  ABS
  OBLIQUES
  ADDUCTORS
  ABDUCTORS
  NECK
  FULL_BODY
}

enum SetType {
  WARMUP
  NORMAL
  DROP
  FAILURE
}

enum MessageRole {
  USER
  ASSISTANT
}

enum SyncEntityType {
  WORKOUT
  EXERCISE_SETTING
}

/// An application account. The administrator curates the shared catalog and manages
/// other accounts; every user owns their own workouts, settings, and conversations.
model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String     @map("password_hash")
  displayName     String     @map("display_name")
  isAdministrator Boolean    @default(false) @map("is_administrator")
  isActive        Boolean    @default(true) @map("is_active")
  weightUnit      WeightUnit @default(KG) @map("weight_unit")
  defaultGymId    String?    @map("default_gym_id")
  defaultGym      Gym?       @relation("UserDefaultGym", fields: [defaultGymId], references: [id], onDelete: SetNull)

  workouts         Workout[]
  exerciseSettings ExerciseSetting[]
  conversations    Conversation[]
  refreshSessions  RefreshSession[]
  syncDeletions    SyncDeletion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([defaultGymId])
  @@map("users")
}

model RefreshSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_sessions")
}

model Brand {
  id   String @id @default(uuid())
  name String @unique

  equipment Equipment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("brands")
}

model Equipment {
  id      String        @id @default(uuid())
  name    String
  type    EquipmentType
  brandId String?       @map("brand_id")
  brand   Brand?        @relation(fields: [brandId], references: [id], onDelete: Restrict)

  exercises Exercise[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([brandId])
  @@map("equipment")
}

model ExerciseGroup {
  id   String @id @default(uuid())
  name String @unique

  exercises Exercise[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("exercise_groups")
}

model Exercise {
  id               String         @id @default(uuid())
  name             String         @unique
  primaryMuscle    MuscleGroup    @map("primary_muscle")
  secondaryMuscles MuscleGroup[]  @map("secondary_muscles")
  equipmentId      String?        @map("equipment_id")
  equipment        Equipment?     @relation(fields: [equipmentId], references: [id], onDelete: Restrict)
  groupId          String?        @map("group_id")
  group            ExerciseGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  isFavorite       Boolean        @default(false) @map("is_favorite")
  isArchived       Boolean        @default(false) @map("is_archived")

  workoutEntries WorkoutExercise[]
  settings       ExerciseSetting[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([primaryMuscle])
  @@index([equipmentId])
  @@index([groupId])
  @@map("exercises")
}

model Gym {
  id      String  @id @default(uuid())
  name    String  @unique
  address String?
  notes   String?

  workouts         Workout[]
  exerciseSettings ExerciseSetting[]
  defaultForUsers  User[]            @relation("UserDefaultGym")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("gyms")
}

model Workout {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gymId     String?   @map("gym_id")
  gym       Gym?      @relation(fields: [gymId], references: [id], onDelete: SetNull)
  name      String?
  startedAt DateTime  @map("started_at")
  endedAt   DateTime? @map("ended_at")
  notes     String?

  entries WorkoutExercise[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, startedAt])
  @@index([gymId])
  @@map("workouts")
}

model WorkoutExercise {
  id         String   @id @default(uuid())
  workoutId  String   @map("workout_id")
  workout    Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseId String   @map("exercise_id")
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  position   Int
  notes      String?
  settings   Json?
  supersetId String?  @map("superset_id")

  sets WorkoutSet[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([workoutId, position])
  @@index([exerciseId])
  @@map("workout_exercises")
}

model WorkoutSet {
  id                String          @id @default(uuid())
  workoutExerciseId String          @map("workout_exercise_id")
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  setNumber         Int             @map("set_number")
  setType           SetType         @default(NORMAL) @map("set_type")
  weightKg          Decimal?        @map("weight_kg") @db.Decimal(6, 2)
  reps              Int?
  distanceM         Decimal?        @map("distance_m") @db.Decimal(10, 2)
  durationSeconds   Int?            @map("duration_seconds")
  isCompleted       Boolean         @default(false) @map("is_completed")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([workoutExerciseId, setNumber])
  @@map("workout_sets")
}

model ExerciseSetting {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId String   @map("exercise_id")
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  gymId      String   @map("gym_id")
  gym        Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  settings   Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, exerciseId, gymId])
  @@index([userId])
  @@index([exerciseId])
  @@index([gymId])
  @@map("exercise_settings")
}

model Conversation {
  id     String  @id @default(uuid())
  userId String  @map("user_id")
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title  String?

  messages Message[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, updatedAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String

  createdAt DateTime @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("messages")
}

/// A tombstone recording a caller-owned deletion, so offline clients can reconcile
/// deletes on their next pull.
model SyncDeletion {
  id         String         @id @default(uuid())
  userId     String         @map("user_id")
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType SyncEntityType @map("entity_type")
  entityId   String         @map("entity_id")
  deletedAt  DateTime       @default(now()) @map("deleted_at")

  @@index([userId, deletedAt])
  @@map("sync_deletions")
}
