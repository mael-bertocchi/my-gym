{
  "name": "@my-gym/backend",
  "description": "The Fastify backend for my-gym, a personal workout tracker.",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "start": "prisma migrate deploy && node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^6.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@google/genai": "^2.9.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.6.0",
    "@sinclair/typebox": "^0.34.49",
    "ajv-formats": "^3.0.1",
    "argon2": "^0.44.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "http-status-codes": "^2.3.0",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.1.0",
    "eslint-plugin-import-x": "^4.16.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.5"
  },
  "allowScripts": {
    "@google/genai@2.10.0": true,
    "@prisma/engines@7.8.0": true,
    "argon2@0.44.0": true,
    "esbuild@0.28.1": true,
    "prisma@7.8.0": true,
    "protobufjs@7.6.4": true,
    "unrs-resolver@1.12.2": true
  }
}
